# Which scanner to use: "tesseract" (default, on-device OCR) | "mock" | "vision"
# Must be VITE_-prefixed so it's exposed to the browser bundle.
# "vision" sends the image to Claude server-side and needs ANTHROPIC_API_KEY below.
VITE_SCANNER=tesseract

# Claude vision scanner (server-side only — never exposed to the browser).
# Get a key at https://console.anthropic.com. Defaults to the cheapest model.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Auth (server-side only). APP_PASSWORD is the password you type to sign in.
# SESSION_SECRET encrypts the login cookie (>=32 chars); generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_PASSWORD=
SESSION_SECRET=

# Database (server-side only). For local dev a file URL works out of the box.
# Prod (Turso): libsql://<db>-<org>.turso.io  + DATABASE_AUTH_TOKEN
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=
