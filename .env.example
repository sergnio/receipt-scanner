# Which (client-side) scanner to use: "tesseract" (default) | "mock"
# Must be VITE_-prefixed so it's exposed to the browser bundle.
VITE_SCANNER=tesseract

# Database (server-side only). For local dev a file URL works out of the box.
# Prod (Turso): libsql://<db>-<org>.turso.io  + DATABASE_AUTH_TOKEN
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=
