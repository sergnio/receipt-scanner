# Which receipt scanner implementation to use: "mock" | "claude"
SCANNER=mock

# Required when SCANNER=claude
ANTHROPIC_API_KEY=

# Database. For local dev a file URL works out of the box.
# Prod (Turso): libsql://<db>-<org>.turso.io  + DATABASE_AUTH_TOKEN
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=
